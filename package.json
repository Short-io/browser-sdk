{
  "name": "@short.io/client-browser",
  "version": "1.0.0",
  "description": "Browser SDK for Short.io API with public key support",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "short.io",
    "url-shortener",
    "browser",
    "sdk",
    "client"
  ],
  "author": "Short.io",
  "license": "MIT",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Short-io/browser-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/Short-io/browser-sdk/issues"
  },
  "homepage": "https://github.com/Short-io/browser-sdk#readme",
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-typescript": "^11.0.0",
    "@vitest/browser": "^3.0.0",
    "@typescript-eslint/eslint-plugin": "^8.36.0",
    "@typescript-eslint/parser": "^8.36.0",
    "eslint": "^9.30.1",
    "msw": "^2.0.0",
    "playwright": "^1.50.0",
    "rollup": "^3.0.0",
    "tslib": "^2.8.1",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "typescript": ">=4.0.0"
  },
  "engines": {
    "node": ">=14"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}